PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
JWT_SECRET=change-me
FRONTEND_URL=https://tu-frontend.vercel.app
GOOGLE_CLIENT_ID=

# Cloudinary (opcional para fotos de progreso)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini IA (opcional; si falta, la app usa generadores locales)
GEMINI_API_KEY=

# Email Resend (recomendado para deploy)
RESEND_API_KEY=
RESEND_FROM=Fitmi <onboarding@resend.dev>

# Email SMTP (fallback local/opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Fitmi <no-reply@example.com>

# Jobs automaticos
ENABLE_ACTIVITY_REMINDERS=true
ACTIVITY_REMINDER_DAYS=1
ACTIVITY_REMINDER_INTERVAL_HOURS=24
ENABLE_PROGRESS_REPORTS=true
PROGRESS_REPORT_DAYS=1
PROGRESS_REPORT_INTERVAL_HOURS=24
