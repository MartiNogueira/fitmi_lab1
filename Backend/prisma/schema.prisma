generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  cliente
  entrenador
  nutricionista
  admin
}

enum Estado {
  pendiente
  aprobado
  rechazado
}

model Usuario {
  id_usuario              Int                       @id @default(autoincrement())
  nombre_usuario          String
  email                   String                    @unique
  contrasena              String
  rol                     Rol                       @default(cliente)
  estado                  Estado                    @default(aprobado)
  created_at              DateTime                  @default(now())
  notificaciones          Notificacion[]            @relation("NotificacionDestinatario")
  planesCreados           PlanAlimenticio[]         @relation("PlanesNutricionista")
  rutinasCreadas          Rutina[]                  @relation("RutinasEntrenador")
  rutinaAsignada          Rutina[]                  @relation("RutinaCliente")
  planAsignado            PlanAlimenticio[]         @relation("PlanCliente")
  ejerciciosCompletados   EjercicioCompletado[]
  comidasCompletadas      ComidaCompletada[]
  pesosCorporales         PesoCorporal[]
  vinculosComoUsuario     Vinculo[]                 @relation("VinculosComoUsuario")
  vinculosComoProfesional Vinculo[]                 @relation("VinculosComoProfesional")
  mensajesEnviados        Mensaje[]                 @relation("MensajesEnviados")
  mensajesRecibidos       Mensaje[]                 @relation("MensajesRecibidos")
  comunidadesCreadas      Comunidad[]               @relation("ComunidadesCreadas")
  solicitudesComunidad    SolicitudComunidad[]      @relation("SolicitudesComunidad")
  postsComunidad          PostComunidad[]           @relation("PostsComunidadAutor")
  likesComunidad          LikePostComunidad[]
  comentariosComunidad    ComentarioPostComunidad[] @relation("ComentariosComunidadAutor")
  fotosProgreso           FotoProgreso[]
}

// tipo: "entrenador" | "nutricionista"
// estado: "pendiente" | "activo" | "rechazado"
model Vinculo {
  id             Int      @id @default(autoincrement())
  usuario_id     Int
  usuario        Usuario  @relation("VinculosComoUsuario", fields: [usuario_id], references: [id_usuario])
  profesional_id Int
  profesional    Usuario  @relation("VinculosComoProfesional", fields: [profesional_id], references: [id_usuario])
  tipo           String
  estado         String   @default("pendiente")
  created_at     DateTime @default(now())

  @@unique([usuario_id, profesional_id, tipo])
}

// dias_semana: número de días de entrenamiento
// ejercicios: [{dia: 1, nombre: "Día 1 - Pecho", ejercicios: [{nombre, series, reps, notas}]}]
model Rutina {
  id            Int                   @id @default(autoincrement())
  nombre        String
  objetivo      String
  dias_semana   Int
  ejercicios    Json
  entrenador_id Int
  entrenador    Usuario               @relation("RutinasEntrenador", fields: [entrenador_id], references: [id_usuario])
  usuario_id    Int?
  usuario       Usuario?              @relation("RutinaCliente", fields: [usuario_id], references: [id_usuario])
  completados   EjercicioCompletado[]
  created_at    DateTime              @default(now())
}

// dias: [{dia: 1, nombre: "Lunes", comidas: [{nombre, momento, descripcion}]}]
model PlanAlimenticio {
  id               Int                @id @default(autoincrement())
  nombre           String
  objetivo         String
  dias             Json
  nutricionista_id Int
  nutricionista    Usuario            @relation("PlanesNutricionista", fields: [nutricionista_id], references: [id_usuario])
  usuario_id       Int?
  usuario          Usuario?           @relation("PlanCliente", fields: [usuario_id], references: [id_usuario])
  completadas      ComidaCompletada[]
  created_at       DateTime           @default(now())
}

model EjercicioCompletado {
  id               Int      @id @default(autoincrement())
  usuario_id       Int
  usuario          Usuario  @relation(fields: [usuario_id], references: [id_usuario])
  rutina_id        Int
  rutina           Rutina   @relation(fields: [rutina_id], references: [id])
  dia_numero       Int
  ejercicio_nombre String
  fecha            DateTime @default(now())
  peso_kg          Float?
  reps_realizadas  String?
  notas            String?
}

model ComidaCompletada {
  id                    Int             @id @default(autoincrement())
  usuario_id            Int
  usuario               Usuario         @relation(fields: [usuario_id], references: [id_usuario])
  plan_id               Int
  plan                  PlanAlimenticio @relation(fields: [plan_id], references: [id])
  dia_numero            Int
  comida_nombre         String
  fecha                 DateTime        @default(now())
  estado                String          @default("completada")
  gramos                Int?
  descripcion_reemplazo String?
}

model PesoCorporal {
  id         Int      @id @default(autoincrement())
  usuario_id Int
  usuario    Usuario  @relation(fields: [usuario_id], references: [id_usuario])
  peso_kg    Float
  fecha      DateTime @default(now())
  created_at DateTime @default(now())
}

model Comunidad {
  id          Int                  @id @default(autoincrement())
  nombre      String               @unique
  descripcion String
  creador_id  Int
  creador     Usuario              @relation("ComunidadesCreadas", fields: [creador_id], references: [id_usuario])
  privada     Boolean              @default(false)
  miembros    SolicitudComunidad[]
  posts       PostComunidad[]
  created_at  DateTime             @default(now())
}

model SolicitudComunidad {
  id           Int       @id @default(autoincrement())
  comunidad_id Int
  comunidad    Comunidad @relation(fields: [comunidad_id], references: [id])
  usuario_id   Int
  usuario      Usuario   @relation("SolicitudesComunidad", fields: [usuario_id], references: [id_usuario])
  estado       String    @default("pendiente")
  created_at   DateTime  @default(now())

  @@unique([comunidad_id, usuario_id])
}

model PostComunidad {
  id           Int                       @id @default(autoincrement())
  comunidad_id Int
  comunidad    Comunidad                 @relation(fields: [comunidad_id], references: [id], onDelete: Cascade)
  autor_id     Int
  autor        Usuario                   @relation("PostsComunidadAutor", fields: [autor_id], references: [id_usuario], onDelete: Cascade)
  contenido    String
  likes        LikePostComunidad[]
  comentarios  ComentarioPostComunidad[]
  created_at   DateTime                  @default(now())

  @@index([comunidad_id, created_at])
  @@index([autor_id])
}

model LikePostComunidad {
  id         Int           @id @default(autoincrement())
  post_id    Int
  post       PostComunidad @relation(fields: [post_id], references: [id], onDelete: Cascade)
  usuario_id Int
  usuario    Usuario       @relation(fields: [usuario_id], references: [id_usuario], onDelete: Cascade)
  created_at DateTime      @default(now())

  @@unique([post_id, usuario_id])
  @@index([usuario_id])
}

model ComentarioPostComunidad {
  id         Int           @id @default(autoincrement())
  post_id    Int
  post       PostComunidad @relation(fields: [post_id], references: [id], onDelete: Cascade)
  autor_id   Int
  autor      Usuario       @relation("ComentariosComunidadAutor", fields: [autor_id], references: [id_usuario], onDelete: Cascade)
  contenido  String
  created_at DateTime      @default(now())

  @@index([post_id, created_at])
  @@index([autor_id])
}

model Mensaje {
  id              Int      @id @default(autoincrement())
  remitente_id    Int
  remitente       Usuario  @relation("MensajesEnviados", fields: [remitente_id], references: [id_usuario])
  destinatario_id Int
  destinatario    Usuario  @relation("MensajesRecibidos", fields: [destinatario_id], references: [id_usuario])
  contenido       String
  leido           Boolean  @default(false)
  created_at      DateTime @default(now())
}

model FotoProgreso {
  id          Int      @id @default(autoincrement())
  usuario_id  Int
  usuario     Usuario  @relation(fields: [usuario_id], references: [id_usuario])
  url         String
  public_id   String
  descripcion String?
  fecha       DateTime @default(now())
  created_at  DateTime @default(now())
}

model Notificacion {
  id              Int      @id @default(autoincrement())
  destinatario_id Int
  destinatario    Usuario  @relation("NotificacionDestinatario", fields: [destinatario_id], references: [id_usuario])
  tipo            String
  mensaje         String
  leida           Boolean  @default(false)
  data            Json?
  created_at      DateTime @default(now())
}

model EmailLog {
  id           Int      @id @default(autoincrement())
  tipo         String
  usuario_id   Int?
  destinatario String
  asunto       String
  created_at   DateTime @default(now())

  @@index([tipo, usuario_id, created_at])
}
